# Copy this file to .env and fill in the values you need.
# .env is loaded automatically at startup — no need to export vars in your shell.

# --- Anthropic (native) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5   # optional; this is the default

# --- OpenAI / OpenAI-compatible (Gemini, Groq, Ollama, DeepSeek, …) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for other providers
# OPENAI_MODEL=gpt-4o-mini                    # optional; this is the default

# --- Provider selection ---
# LLM_PROVIDER=anthropic   # force a provider; otherwise auto-detected from keys above
